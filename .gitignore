# Bundles originales de OPCloud (42 MB main.js + complementos)
# Propiedad de OPCloud Ltd. Se regeneran con: bash setup.sh
_local/

# Decompilacion de webcrack (809 modulos, 91 MB)
# Se regenera con: bash setup.sh
decompiled/

# opm-extracted/ SI se versiona: derivado curado de decompiled/ (~8 MiB,
# 349 archivos OPM legibles). Es la forma navegable y trazable que usa el
# resto del repo (app/, AGENTS.md, agentes) como referencia OPM. Se regenera
# con `node opm-extracted/tools/{extract,refactor,build-index}.mjs`.
# (no entry — versionado intencionalmente)

# App build artifacts
app/node_modules/
app/dist/
app/.vite/
app/bun.lockb
app/*.tsbuildinfo
app/test-results/
app/playwright-report/
app/.tutor-corpus/
app/.tutor-corpus.lock/
/test-results/

# Reportes de auditoría generados; el estado versionado vive en docs/handoff-AAAA-MM-DD.md
docs/REPORTE-EJECUTIVO.md

# Secrets de despliegue (docker compose los lee; JAMÁS versionar)
.env

# Archivos temporales
.claude/
.codex/
.opencode/
.config/
.playwright-mcp/
_archivo/
*.tar.gz
.DS_Store
tmp/
