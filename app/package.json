{
  "name": "opm-modeler",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "bun test src",
    "browser:smoke": "playwright test",
    "browser:preview": "playwright test --config playwright.preview.config.ts e2e/25-produccion-preview.preview.spec.ts",
    "check": "bun run typecheck && bun run test",
    "lint": "eslint src/",
    "quality:gate": "bun run scripts/quality-ledger.mjs --markdown --check",
    "gate:refactor": "bun run check && bun run lint && bun run build && bun run browser:smoke && node ../docs/historias-usuario-v2/tools/progress-dashboard.mjs --sync-real && bun run quality:gate",
    "security:scan": "bun pm scan",
    "visual:audit": "node scripts/in-vivo-test.mjs",
    "visual:deep": "node scripts/in-vivo-deep-checks.mjs",
    "ux:eval": "bun run scripts/evaluacion-ux-permanente.mjs",
    "bug-capture:api": "bun run scripts/bug-capture-api.ts"
  },
  "dependencies": {
    "@fontsource-variable/inter-tight": "^5.2.7",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "jointjs": "^3.7.7",
    "preact": "^10.25.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@preact/preset-vite": "^2.10.0",
    "@socketsecurity/bun-security-scanner": "^1.1.2",
    "@types/bun": "^1.3.13",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^10.2.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
