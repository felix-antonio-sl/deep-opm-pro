{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "name": "opforja-codex",
  "version": "1.0.0",
  "description": "Design tokens for the Codex proposal of OpForja (OPM editor). Editorial, marginalia, type-led.",

  "color": {
    "paper":        { "value": "#fafaf8", "type": "color", "comment": "Main background — gallery off-white" },
    "paperWarm":    { "value": "#f4f3ec", "type": "color", "comment": "Secondary surfaces (marginalia divider, alert callout bg)" },
    "ink":          { "value": "#171511", "type": "color", "comment": "Primary ink — paper-black with warm hint" },
    "inkMid":       { "value": "#5a564c", "type": "color", "comment": "Body secondary, italic labels" },
    "inkSoft":      { "value": "#a39e92", "type": "color", "comment": "Metadata, kickers, mono numbers" },
    "inkFaint":     { "value": "#cfcbc1", "type": "color", "comment": "Inline separators (·), 'off' elements" },
    "rule":         { "value": "#e4e0d6", "type": "color", "comment": "Hairlines normales (1px)" },
    "ruleStrong":   { "value": "#c7c2b6", "type": "color", "comment": "Hairlines de divisor estructural" },

    "opm": {
      "object":   { "value": "#3a6b4d", "type": "color", "comment": "OBJETO border + class badge — V-63 canónico" },
      "process":  { "value": "#26467a", "type": "color", "comment": "PROCESO border + class badge — V-63 canónico" },
      "state":    { "value": "#7e8338", "type": "color", "comment": "ESTADO border + class badge — V-63 canónico" },
      "stateFill":{ "value": "#ece9e1", "type": "color", "comment": "ESTADO stadium fill — gris claro canónico" }
    },

    "crimson": { "value": "#8e2a2e", "type": "color", "comment": "Editorial accent — RESERVADO a UI (V-203): selection, alerts, marcas tipográficas" }
  },

  "font": {
    "serif": { "value": "\"Inria Serif\", Georgia, serif", "type": "fontFamily" },
    "sans":  { "value": "\"Inria Sans\", system-ui, sans-serif", "type": "fontFamily" },
    "mono":  { "value": "\"JetBrains Mono\", ui-monospace, monospace", "type": "fontFamily" }
  },

  "fontSize": {
    "fs9":     { "value": "9px",    "comment": "Footer mono, severidades" },
    "fs10":    { "value": "10px",   "comment": "JetBrains Mono shortcuts, kicker uppercase" },
    "fs11":    { "value": "11px",   "comment": "Metadatos sans, footer keys label, OPL marginalia note" },
    "fs12":    { "value": "12px",   "comment": "Cuerpo secundario, inspector fields" },
    "fs13":    { "value": "13.5px", "comment": "Cuerpo principal OPL — Inria Serif 13.5/1.55" },
    "fs14":    { "value": "14px",   "comment": "Labels destacados (tree-row)" },
    "fs17":    { "value": "17px",   "comment": "Etiquetas dentro de objetos OPM" },
    "fs20":    { "value": "20px",   "comment": "Etiquetas dentro de procesos / compounds" },
    "fs22":    { "value": "22px",   "comment": "Wordmark Opforja, títulos de columna, input del command palette" }
  },

  "fontWeight": {
    "regular":  { "value": 400 },
    "medium":   { "value": 500, "comment": "tree-row current, mono semibold" },
    "semibold": { "value": 600, "comment": "segmented active option" },
    "bold":     { "value": 700, "comment": "títulos serif, objetos OPL" }
  },

  "letterSpacing": {
    "tight":    { "value": "-0.01em",  "comment": "títulos serif grandes" },
    "body":     { "value": "-0.005em", "comment": "cuerpo serif" },
    "mono":     { "value": "0.04em",   "comment": "mono inline pequeño" },
    "kbd":      { "value": "0.06em",   "comment": "shortcuts mono" },
    "meta":     { "value": "0.08em",   "comment": "identificadores mono junto a texto serif" },
    "mark":     { "value": "0.12em",   "comment": "marcas como '△ CRÍTICA'" },
    "kicker":   { "value": "0.18em",   "comment": "kickers cortos sans (OBJETO ·)" },
    "section":  { "value": "0.22em",   "comment": "kickers de sección uppercase (ÍNDICE, ESTADOS)" }
  },

  "lineHeight": {
    "tight":  { "value": 1.1,  "comment": "títulos grandes" },
    "body":   { "value": 1.45, "comment": "tree-row, fields" },
    "opl":    { "value": 1.55, "comment": "OPL note body" },
    "quote":  { "value": 1.5,  "comment": "citas en cursiva" }
  },

  "layout": {
    "frame":   { "width": "1700px", "height": "950px" },
    "colLeft": { "value": "210px" },
    "colRight":{ "value": "360px" },
    "headerH": { "value": "60px"  },
    "footerH": { "value": "44px"  }
  },

  "stroke": {
    "object":   { "value": "1.5px", "type": "dimension" },
    "process":  { "value": "1.5px", "type": "dimension" },
    "state":    { "value": "1.2px", "type": "dimension" },
    "link":     { "value": "1px",   "type": "dimension" },
    "triangle": { "value": "1.2px", "type": "dimension" }
  },

  "glyphs": {
    "selectionMark":  { "value": "※", "comment": "U+203B reference mark — selección única" },
    "warning":        { "value": "△", "comment": "U+25B3 white up-pointing triangle — severidad" },
    "currentMarker":  { "value": "▸", "comment": "U+25B8 — item actual en tree" },
    "separator":      { "value": "·", "comment": "U+00B7 middle dot — separador inline" },
    "create":         { "value": "+", "comment": "U+002B — acción de creación" },
    "delete":         { "value": "⌫", "comment": "U+232B — eliminar" },
    "return":         { "value": "↵", "comment": "U+21B5 — confirmar" },
    "command":        { "value": "⌘", "comment": "U+2318 — modificador macOS" },
    "control":        { "value": "⌃", "comment": "U+2303 — modificador" },
    "shift":          { "value": "⇧", "comment": "U+21E7 — modificador" },
    "dismiss":        { "value": "✕", "comment": "U+2715 — cerrar/limpiar" }
  }
}
